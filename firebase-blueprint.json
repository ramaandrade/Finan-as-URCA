{
  "entities": {
    "UserAccess": {
      "title": "User Access",
      "description": "List of authorized student emails.",
      "type": "object",
      "properties": {
        "emails": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of authorized emails."
        }
      },
      "required": ["emails"]
    },
    "Assessment": {
      "title": "Assessment",
      "description": "Assessment details and base knowledge.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "baseText": { "type": "string", "description": "The content extracted from PDF/TXT." },
        "timeLimit": { "type": "integer", "description": "Time in minutes." },
        "questionCount": { "type": "integer", "description": "Number of questions." },
        "pointsPerQuestion": { "type": "number", "description": "Points awarded per correct answer." },
        "status": { "type": "string", "enum": ["Available", "Unavailable"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "exerciseUrl": { "type": "string", "description": "Base64 or URL of the exercise file." },
        "exerciseName": { "type": "string", "description": "Name of the exercise file." },
        "glossaryUrl": { "type": "string", "description": "Base64 or URL of the glossary file." },
        "glossaryName": { "type": "string", "description": "Name of the glossary file." }
      },
      "required": ["title", "baseText", "timeLimit", "questionCount", "pointsPerQuestion", "status"]
    },
    "Result": {
      "title": "Result",
      "description": "Student assessment performance.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "assessmentId": { "type": "string" },
        "assessmentTitle": { "type": "string" },
        "score": { "type": "number" },
        "pointsPerQuestion": { "type": "number" },
        "answers": { "type": "array" },
        "questions": { "type": "array" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "assessmentId", "assessmentTitle", "score", "pointsPerQuestion", "answers", "questions", "timestamp"]
    },
    "Student": {
      "title": "Student",
      "description": "Student profile information.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "lastLogin": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "createdAt"]
    },
    "AppSettings": {
      "title": "App Settings",
      "description": "Global application settings.",
      "type": "object",
      "properties": {
        "isLocked": {
          "type": "boolean",
          "description": "Whether the app is locked for non-admin users."
        }
      },
      "required": ["isLocked"]
    }
  },
  "firestore": {
    "/config/access": {
      "schema": "UserAccess",
      "description": "Global configuration for authorized emails."
    },
    "/config/settings": {
      "schema": "AppSettings",
      "description": "Global application settings."
    },
    "/assessments/{assessmentId}": {
      "schema": "Assessment",
      "description": "Collection of assessments."
    },
    "/results/{resultId}": {
      "schema": "Result",
      "description": "Collection of student results."
    },
    "/students/{studentId}": {
      "schema": "Student",
      "description": "Collection of registered students."
    }
  }
}
