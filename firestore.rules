rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email.lower() == "rama.lucas@urca.br");
    }

    // Config access (authorized emails)
    match /config/access {
      allow read: if true; // Needed for login check
      allow write: if isAdmin();
    }

    // App settings (lock state)
    match /config/settings {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Assessments
    match /assessments/{assessmentId} {
      allow read: if true;
      allow write: if isAdmin() && 
        request.resource.data.title is string &&
        request.resource.data.baseText is string &&
        request.resource.data.timeLimit is int &&
        request.resource.data.questionCount is int &&
        request.resource.data.pointsPerQuestion is number;
    }

    // Results
    match /results/{resultId} {
      allow create: if isAuthenticated() &&
        request.resource.data.email == request.auth.token.email &&
        request.resource.data.score is number &&
        request.resource.data.pointsPerQuestion is number &&
        request.resource.data.answers is list &&
        request.resource.data.questions is list;
      allow read: if isAdmin() || (isAuthenticated() && request.auth.token.email == resource.data.email);
      allow update, delete: if isAdmin();
    }

    // Students
    match /students/{studentId} {
      allow read: if isAdmin() || (isAuthenticated() && (request.auth.uid == studentId || request.auth.token.email.lower() == studentId.lower()));
      allow create, update: if isAdmin() || (isAuthenticated() && (request.auth.uid == studentId || request.auth.token.email.lower() == studentId.lower()));
      allow delete: if isAdmin();
    }
  }
}
